{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "scripts/**",
        "tsconfig.json",
        "tsconfig.build.json",
        "package.json",
        "README.md"
      ],
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "tests/**",
        "vitest.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:harness": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:fuzz": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
